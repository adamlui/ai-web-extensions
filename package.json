{
  "name": "@adamlui/ai-web-extensions",
  "private": true,
  "description": "AI browser extensions & userscripts to augment your web experience",
  "author": {
    "name": "Adam Lui",
    "email": "adam@kudoai.com",
    "url": "https://github.com/adamlui"
  },
  "homepage": "https://github.com/adamlui/ai-web-extensions/#readme",
  "bugs": {
    "url": "https://github.com/adamlui/ai-web-extensions/issues",
    "email": "adam@kudoai.com"
  },
  "license": "MIT",
  "funding": [
    {
      "type": "github",
      "url": "http://github.com/sponsors/adamlui"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/adamlui"
    },
    {
      "type": "paypal",
      "url": "https://paypal.me/adamlui"
    }
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adamlui/ai-web-extensions.git"
  },
  "scripts": {
    "prepare": "husky",
    "dev:chatbots": "node utils/remote-run https://cdn.jsdelivr.net/gh/adamlui/userscripts/utils/dev/chatbots.min.js --cache",
    "dev:chatbot": "npm run dev:chatbots",
    "build:css": "scss-to-css . dist",
    "lint": "eslint . --cache",
    "lint:all": "eslint .",
    "lint:fix": "eslint . --fix --cache",
    "lint:fix-all": "eslint . --fix",
    "bump:chatbots": "node utils/remote-run https://cdn.jsdelivr.net/gh/adamlui/userscripts/utils/bump/chatbots.min.js --cache",
    "bump:chatbots-nc": "npm run bump:chatbots",
    "bump:chatbots-np": "npm run bump:chatbots -- --no-push",
    "bump:chatbot": "npm run bump:chatbots",
    "bump:chatbot-nc": "npm run bump:chatbots-nc",
    "bump:chatbot-np": "npm run bump:chatbots-np",
    "bump:chatgpt": "node utils/bump/chatgpt.mjs",
    "bump:res": "node utils/bump/userscript-requires.mjs --cache && node utils/bump/extension-resources.mjs",
    "bump:ext": "node utils/bump/extension-manifests.mjs --cache",
    "bump:ext-nc": "npm run bump:ext -- --no-commit",
    "bump:ext-np": "npm run bump:ext -- --no-push",
    "bump:chrome": "npm run bump:ext -- --chrome",
    "bump:chromium": "npm run bump:chrome",
    "bump:ff": "npm run bump:ext -- --ff",
    "bump:firefox": "npm run bump:ff"
  },
  "devDependencies": {
    "@adamlui/scss-to-css": "^2.4.4",
    "@eslint/css": "^1.4.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.1",
    "@eslint/markdown": "^8.0.3",
    "@html-eslint/eslint-plugin": "^0.64.0",
    "@html-eslint/parser": "^0.64.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.3.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-regexp": "^3.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "ssri": "^14.0.0"
  }
}
